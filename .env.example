# API Configuration
API_KEY=your-secure-api-key-here
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
ENVIRONMENT=production

# Model Configuration
MODEL_TYPE=distilbert  # Options: baseline, distilbert
MODEL_PATH=models/best_model.pkl
MAX_LENGTH=128
BATCH_SIZE=32

# Data Configuration
DATA_PATH=../yelp_academic_dataset_review.json
SAMPLE_SIZE=100000
TEST_SIZE=0.2
RANDOM_STATE=42

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=sentiment-analysis

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT=100/minute
